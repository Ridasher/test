{
  "name": "MessageDraft",
  "type": "object",
  "properties": {
    "recipient_name": {
      "type": "string",
      "description": "Nom du destinataire"
    },
    "context": {
      "type": "string",
      "enum": [
        "prise_de_contact",
        "suivi",
        "remerciement",
        "proposition",
        "autre"
      ],
      "description": "Type de contexte"
    },
    "context_details": {
      "type": "string",
      "description": "D\u00e9tails suppl\u00e9mentaires sur le contexte"
    },
    "generated_message": {
      "type": "string",
      "description": "Le message g\u00e9n\u00e9r\u00e9 par l'IA"
    },
    "status": {
      "type": "string",
      "enum": [
        "brouillon",
        "copi\u00e9",
        "envoy\u00e9"
      ],
      "default": "brouillon",
      "description": "Statut du brouillon"
    }
  },
  "required": [
    "recipient_name",
    "context"
  ]
}